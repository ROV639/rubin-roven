---
interface Props {
  title?: string;
}
const { title = 'Rubin Roven' } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen">
    <header class="border-b border-neutral-800 px-6 py-4">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-xl font-light tracking-widest uppercase">Rubin Roven</a>
        <nav class="flex gap-6 text-sm text-neutral-400">
          <a href="/" class="hover:text-white transition">Gallery</a>
          <a href="/about" class="hover:text-white transition">About</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-neutral-800 px-6 py-8 mt-20 text-center text-sm text-neutral-500">
      &copy; 2026 Rubin Roven
    </footer>
  </body>
</html>