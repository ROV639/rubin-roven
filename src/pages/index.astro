---
import promptsData from '../data/prompts.json';
import BaseLayout from '../layouts/BaseLayout.astro';

const PAGE_SIZE = 30;

const prompts = promptsData as Array<{
  img: string;
  link: string;
  author: string;
  prompt: string;
  title: string;
  category: string;
}>;

const categories = [
  { key: 'all', label: '全部', icon: '◆' },
  { key: 'ecommerce', label: '电商', icon: '◈' },
  { key: 'ad', label: '广告', icon: '◇' },
  { key: 'portrait', label: '人像', icon: '○' },
  { key: 'poster', label: '海报', icon: '□' },
  { key: 'character', label: '角色', icon: '△' },
  { key: 'ui', label: '界面', icon: '▣' },
  { key: 'comparison', label: '对比', icon: '◐' },
  { key: 'landscape', label: '风景', icon: '▽' },
];

const categoryNames: Record<string, string> = {
  ad: '广告创意',
  character: '角色设计',
  comparison: '对比实验',
  ecommerce: '电商产品',
  portrait: '人像摄影',
  poster: '海报插画',
  ui: '界面设计',
  landscape: '风景建筑',
};

const totalPages = Math.ceil(prompts.length / PAGE_SIZE);
const initialPrompts = prompts.slice(0, PAGE_SIZE);
---

<BaseLayout title="Rubin Roven Prompts">
  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center" style="background: rgba(7,18,9,0.95);">
    <button id="lightbox-close" class="absolute top-6 right-6 w-10 h-10 rounded-full border border-[rgba(0,212,154,0.3)] flex items-center justify-center text-[rgba(200,230,215,0.6)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all">✕</button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg" />
  </div>

  <!-- Hero Section -->
  <section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden">
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <div class="inline-block text-xs tracking-[0.3em] uppercase px-4 py-1.5 rounded-full border mb-6" style="background: rgba(0,212,154,0.1); color: var(--accent); border-color: rgba(0,212,154,0.25);">
        GPT Image 2 · 精选提示词
      </div>

      <h1 class="text-4xl md:text-6xl font-light tracking-[0.1em] leading-none mb-4 artistic-title" style="color: var(--gold-text);">
        Rubin Roven Prompts
      </h1>

      <p class="text-xs tracking-widest uppercase mb-3" style="color: rgba(197,165,114,0.5);">{prompts.length} Prompts · 第1/{totalPages}页</p>
      <p class="text-base font-light leading-relaxed max-w-xl mx-auto mb-8" style="color: var(--gold-text);">
        高质量 GPT-Image-2 提示词<br/>
        涵盖电商、广告、人像、海报等{categories.filter(c => c.key !== 'all').length}大分类
      </p>

      <div class="relative max-w-md mx-auto">
        <input
          type="text"
          id="search-input"
          placeholder="搜索提示词..."
          class="w-full px-6 py-3 rounded-full border text-center text-sm tracking-wider transition-all duration-300"
          style="background: rgba(14,30,18,0.8); border-color: rgba(0,212,154,0.25); color: var(--text-primary);"
        />
        <span class="absolute left-6 top-1/2 -translate-y-1/2" style="color: var(--text-dim);">🔍</span>
      </div>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="sticky top-0 z-40 py-4 px-6" style="background: rgba(7,18,9,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,212,154,0.2);">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-wrap justify-center gap-2" id="category-tabs">
        {categories.map((cat, i) => (
          <button
            data-category={cat.key}
            class="px-5 py-2 text-xs tracking-[0.15em] uppercase rounded-full transition-all duration-300 border"
            style={i === 0
              ? 'background: var(--accent); color: #071209; border-color: var(--accent);'
              : 'border-color: rgba(0,212,154,0.25); color: rgba(200,230,215,0.5);'}
          >
            <span class="mr-1" style="color: rgba(197,165,114,0.8);">{cat.icon}</span><span class="cat-label">{cat.label}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Prompts Grid -->
  <section class="max-w-7xl mx-auto px-6 py-12">
    <div id="prompts-grid" class="columns-2 md:columns-3 lg:columns-4 gap-4" style="column-gap: 1rem;">
      {initialPrompts.map((p, idx) => (
        <div
          class="prompt-card overflow-hidden transition-all duration-400"
          data-category={p.category}
          data-title={p.title.toLowerCase()}
          data-idx={idx}
          style="background: #0a1f12;"
        >
          <!-- Image (click to lightbox) -->
          <div class="overflow-hidden relative cursor-pointer" onclick={`openLightbox('${p.img}', '${p.title.replace(/'/g, "\\'")}')`}>
            <img
              src={p.img}
              alt={p.title}
              class="w-full h-auto object-contain transition-transform duration-500 hover:scale-105"
              loading="lazy"
              style="max-height: 280px;"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xs tracking-widest" style="text-shadow: 0 2px 8px rgba(0,0,0,0.8);">点击放大</span>
            </div>
          </div>

          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] tracking-[0.2em] uppercase px-2 py-1 rounded-full border" style="color: var(--accent); border-color: rgba(0,212,154,0.25);">
                {categoryNames[p.category] || p.category}
              </span>
              {p.author && (
                <span class="text-[10px] tracking-wider" style="color: rgba(200,230,215,0.5);">
                  {p.author}
                </span>
              )}
            </div>

            <h3 class="text-lg font-light tracking-wide mb-3" style="color: var(--text-primary); font-family: 'Cormorant Garamond', serif;">
              {p.title}
            </h3>

            <!-- Prompt preview -->
            <div class="prompt-preview text-xs p-3 rounded-lg mb-4 overflow-hidden" style="background: rgba(0,0,0,0.3); color: rgba(200,230,215,0.5);">
              <p class="line-clamp-3">{p.prompt}</p>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
              <button
                onclick={`event.stopPropagation(); copyPromptText(${idx})`}
                data-prompt={p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-3 py-1.5 rounded-full border transition-all duration-300"
                style="border-color: rgba(0,212,154,0.25); color: var(--accent);"
              >
                <span>📋</span> 复制
              </button>
              <button onclick={`togglePrompt(${idx})`} class="prompt-toggle text-xs" style="color: rgba(197,165,114,0.7);">
                点击展开完整提示词 ↓
              </button>
            </div>
          </div>

          <!-- Full prompt (hidden) -->
          <div class="prompt-full hidden px-5 pb-5">
            <div class="mb-3">
              <p class="text-[10px] tracking-widest uppercase mb-2" style="color: var(--accent);">提示词原文</p>
              <div class="text-xs p-4 rounded-lg overflow-auto" style="background: rgba(0,0,0,0.4); color: var(--text-primary); max-height: 300px;">
                <pre class="whitespace-pre-wrap text-xs leading-relaxed">{p.prompt}</pre>
              </div>
            </div>
            <div class="flex items-center justify-between pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
              <button
                onclick={`event.stopPropagation(); copyPromptText(${idx})`}
                data-prompt={p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
                style="background: var(--accent); color: #071209;"
              >
                <span>✓</span> 复制提示词
              </button>
              <button onclick={`togglePrompt(${idx})`} class="prompt-toggle text-xs px-3 py-1.5 rounded-full border" style="border-color: rgba(0,212,154,0.25); color: rgba(197,165,114,0.7);">
                收起
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-2xl mb-2" style="color: var(--gold-text); font-family: 'Cormorant Garamond', serif;">暂无匹配</p>
      <p class="text-sm" style="color: rgba(200,230,215,0.5);">尝试其他关键词或分类</p>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="flex justify-center items-center gap-2 mt-8 py-6">
      <button id="prev-btn" class="px-4 py-2 rounded-full border text-xs tracking-wider transition-all duration-300 disabled:opacity-30" style="border-color: rgba(0,212,154,0.25); color: var(--accent);" disabled>
        ← 上一页
      </button>
      <span id="page-info" class="px-4 py-2 text-xs tracking-wider" style="color: var(--gold-text);">
        1 / {totalPages}
      </span>
      <button id="next-btn" class="px-4 py-2 rounded-full border text-xs tracking-wider transition-all duration-300" style="border-color: rgba(0,212,154,0.25); color: var(--accent);">
        下一页 →
      </button>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t py-10 px-6" style="border-color: rgba(0,212,154,0.2);">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-xs tracking-widest uppercase mb-4" style="color: var(--gold-text);">Rubin Roven Prompts</p>
      <p style="color: rgba(200,230,215,0.5);">
        基于 GPT Image 2 · 仅供学习参考
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Category tabs - icon gold, label dim */
  .cat-label { color: rgba(200,230,215,0.5); }
  button[data-category]:hover .cat-label { color: rgba(197,165,114,0.9); }
  button[data-category][style*="background: var(--accent)"] .cat-label { color: #071209; }

  .prompt-card {
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }

  .prompt-card:hover {
    box-shadow: 0 0 30px rgba(0,212,154,0.2);
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #071209; }
  ::-webkit-scrollbar-thumb { background: rgba(0,212,154,0.25); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

  /* Artistic title font */
  .artistic-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 600;
    letter-spacing: 0.06em;
  }
</style>

<script define:vars={{ initialPrompts, PAGE_SIZE, totalPages }}>
{
  const tabs = document.querySelectorAll('#category-tabs button');
  const grid = document.getElementById('prompts-grid');
  const searchInput = document.getElementById('search-input');
  const emptyState = document.getElementById('empty-state');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxClose = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const pageInfo = document.getElementById('page-info');

  let currentPage = 1;
  let currentCategory = 'all';
  let currentSearch = '';
  let allPrompts = null; // Lazy load

  const categoryNames = {
    ad: '广告创意', character: '角色设计', comparison: '对比实验',
    ecommerce: '电商产品', portrait: '人像摄影', poster: '海报插画',
    ui: '界面设计', landscape: '风景建筑',
  };

  // Lightbox
  window.openLightbox = function(imgSrc, title) {
    lightboxImg.src = imgSrc;
    lightboxImg.alt = title;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  window.closeLightbox = function() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  };

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // Load all prompts on demand
  async function loadAllPrompts() {
    if (allPrompts) return allPrompts;
    try {
      const res = await fetch('/data/prompts.json');
      allPrompts = await res.json();
    } catch (e) {
      console.error('Failed to load prompts', e);
      allPrompts = initialPrompts;
    }
    return allPrompts;
  }

  // Get filtered prompts
  async function getFilteredPrompts() {
    const prompts = await loadAllPrompts();
    return prompts.filter(p => {
      const matchCat = currentCategory === 'all' || p.category === currentCategory;
      const matchSearch = currentSearch === '' || p.title.toLowerCase().includes(currentSearch);
      return matchCat && matchSearch;
    });
  }

  // Render page
  async function renderPage(page) {
    const prompts = await getFilteredPrompts();
    const totalFilteredPages = Math.ceil(prompts.length / PAGE_SIZE);
    if (page < 1) page = 1;
    if (page > totalFilteredPages) page = totalFilteredPages || 1;
    currentPage = page;

    const start = (page - 1) * PAGE_SIZE;
    const pageItems = prompts.slice(start, start + PAGE_SIZE);

    grid.innerHTML = pageItems.map((p, i) => `
      <div class="prompt-card overflow-hidden transition-all duration-400"
           data-category="${p.category}" data-title="${p.title.toLowerCase()}" data-idx="${start + i}"
           style="background: #0a1f12;">
        <div class="overflow-hidden relative cursor-pointer" onclick="openLightbox('${p.img.replace(/'/g, "\\'")}', '${p.title.replace(/'/g, "\\'")}')">
          <img src="${p.img}" alt="${p.title}" class="w-full h-auto object-contain transition-transform duration-500 hover:scale-105"
               loading="lazy" style="max-height: 280px;" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white text-xs tracking-widest" style="text-shadow: 0 2px 8px rgba(0,0,0,0.8);">点击放大</span>
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[10px] tracking-[0.2em] uppercase px-2 py-1 rounded-full border" style="color: var(--accent); border-color: rgba(0,212,154,0.25);">
              ${categoryNames[p.category] || p.category}
            </span>
            ${p.author ? `<span class="text-[10px] tracking-wider" style="color: rgba(200,230,215,0.5);">${p.author}</span>` : ''}
          </div>
          <h3 class="text-lg font-light tracking-wide mb-3" style="color: var(--text-primary); font-family: 'Cormorant Garamond', serif;">
            ${p.title}
          </h3>
          <div class="prompt-preview text-xs p-3 rounded-lg mb-4 overflow-hidden" style="background: rgba(0,0,0,0.3); color: rgba(200,230,215,0.5);">
            <p class="line-clamp-3">${p.prompt}</p>
          </div>
          <div class="flex items-center justify-between pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
            <button onclick="event.stopPropagation(); copyPromptText(${start + i})"
                    data-prompt="${p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}"
                    class="text-xs tracking-wider uppercase flex items-center gap-2 px-3 py-1.5 rounded-full border transition-all duration-300"
                    style="border-color: rgba(0,212,154,0.25); color: var(--accent);">
              <span>📋</span> 复制
            </button>
            <button onclick="togglePrompt(${start + i})" class="prompt-toggle text-xs" style="color: rgba(197,165,114,0.7);">
              点击展开完整提示词 ↓
            </button>
          </div>
        </div>
        <div class="prompt-full hidden px-5 pb-5">
          <div class="mb-3">
            <p class="text-[10px] tracking-widest uppercase mb-2" style="color: var(--accent);">提示词原文</p>
            <div class="text-xs p-4 rounded-lg overflow-auto" style="background: rgba(0,0,0,0.4); color: var(--text-primary); max-height: 300px;">
              <pre class="whitespace-pre-wrap text-xs leading-relaxed">${p.prompt}</pre>
            </div>
          </div>
          <div class="flex items-center justify-between pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
            <button onclick="event.stopPropagation(); copyPromptText(${start + i})"
                    data-prompt="${p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}"
                    class="text-xs tracking-wider uppercase flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
                    style="background: var(--accent); color: #071209;">
              <span>✓</span> 复制提示词
            </button>
            <button onclick="togglePrompt(${start + i})" class="prompt-toggle text-xs px-3 py-1.5 rounded-full border" style="border-color: rgba(0,212,154,0.25); color: rgba(197,165,114,0.7);">
              收起
            </button>
          </div>
        </div>
      </div>
    `).join('');

    const totalFiltered = Math.ceil(prompts.length / PAGE_SIZE);
    pageInfo.textContent = `${page} / ${totalFiltered || 1}`;
    prevBtn.disabled = page <= 1;
    nextBtn.disabled = page >= totalFiltered;
    emptyState?.classList.toggle('hidden', prompts.length > 0);
  }

  // Pagination
  prevBtn?.addEventListener('click', () => renderPage(currentPage - 1));
  nextBtn?.addEventListener('click', () => renderPage(currentPage + 1));

  // Category filter
  tabs.forEach(tab => {
    tab.addEventListener('click', async () => {
      currentCategory = tab.dataset.category;
      tabs.forEach(t => {
        t.style.background = 'transparent';
        t.style.color = 'rgba(200,230,215,0.5)';
        t.style.borderColor = 'rgba(0,212,154,0.25)';
      });
      tab.style.background = 'var(--accent)';
      tab.style.color = '#071209';
      tab.style.borderColor = 'var(--accent)';
      await loadAllPrompts();
      renderPage(1);
    });
  });

  // Search
  searchInput?.addEventListener('input', async (e) => {
    currentSearch = e.target.value.toLowerCase();
    await loadAllPrompts();
    renderPage(1);
  });

  // Toggle prompt
  window.togglePrompt = function(idx) {
    const card = grid.querySelector(`[data-idx="${idx}"]`);
    if (!card) return;
    const preview = card.querySelector('.prompt-preview');
    const full = card.querySelector('.prompt-full');
    const toggleBtns = card.querySelectorAll('.prompt-toggle');
    if (full?.classList.contains('hidden')) {
      full.classList.remove('hidden');
      preview?.classList.add('hidden');
      toggleBtns.forEach(b => { b.textContent = '收起'; b.style.color = 'rgba(197,165,114,0.7)'; });
    } else {
      full?.classList.add('hidden');
      preview?.classList.remove('hidden');
      toggleBtns.forEach(b => b.textContent = '点击展开完整提示词 ↓');
    }
  };

  // Copy prompt
  window.copyPromptText = function(idx) {
    const btn = event.target.closest('button');
    if (!btn) return;
    const promptData = btn.dataset.prompt;
    navigator.clipboard.writeText(promptData).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = '<span>✓</span> 已复制';
      setTimeout(() => { btn.innerHTML = original; }, 1500);
    });
  };
}
</script>