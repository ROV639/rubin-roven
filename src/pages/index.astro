---
import promptsData from '../data/prompts.json';
import BaseLayout from '../layouts/BaseLayout.astro';

const prompts = promptsData as Array<{
  img: string;
  link: string;
  author: string;
  prompt: string;
  title: string;
  category: string;
}>;

const categories = [
  { key: 'all', label: '全部', icon: '◆' },
  { key: 'ecommerce', label: '电商', icon: '◈' },
  { key: 'ad', label: '广告', icon: '◇' },
  { key: 'portrait', label: '人像', icon: '○' },
  { key: 'poster', label: '海报', icon: '□' },
  { key: 'character', label: '角色', icon: '△' },
  { key: 'ui', label: '界面', icon: '▣' },
  { key: 'comparison', label: '对比', icon: '◐' },
];

const categoryNames: Record<string, string> = {
  ad: '广告创意',
  character: '角色设计',
  comparison: '对比实验',
  ecommerce: '电商产品',
  portrait: '人像摄影',
  poster: '海报插画',
  ui: '界面设计',
};
---

<BaseLayout title="Rubin Roven Prompts">
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden">
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <div class="inline-block text-xs tracking-[0.3em] uppercase px-4 py-1.5 rounded-full border mb-8" style="background: rgba(0,212,154,0.1); color: var(--accent); border-color: rgba(0,212,154,0.25);">
        GPT Image 2 · 精选提示词
      </div>

      <h1 class="text-5xl md:text-7xl font-light tracking-[0.1em] leading-none mb-6" style="font-family: 'Cormorant Garamond', serif; color: var(--gold-text);">
        Rubin Roven Prompts
      </h1>

      <p class="text-lg font-light leading-relaxed max-w-xl mx-auto mb-10" style="color: var(--text-dim);">
        {prompts.length}+ 高质量 GPT-Image-2 提示词<br/>
        涵盖电商、广告、人像、海报等7大分类
      </p>

      <div class="relative max-w-md mx-auto">
        <input
          type="text"
          id="search-input"
          placeholder="搜索提示词..."
          class="w-full px-6 py-4 rounded-full border text-center text-sm tracking-wider transition-all duration-300"
          style="background: rgba(14,30,18,0.8); border-color: rgba(0,212,154,0.25); color: var(--text-primary);"
        />
        <span class="absolute left-6 top-1/2 -translate-y-1/2" style="color: var(--text-dim);">🔍</span>
      </div>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="sticky top-0 z-40 py-4 px-6" style="background: rgba(7,18,9,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,212,154,0.2);">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-wrap justify-center gap-2" id="category-tabs">
        {categories.map((cat, i) => (
          <button
            data-category={cat.key}
            class="px-5 py-2 text-xs tracking-[0.15em] uppercase rounded-full transition-all duration-300 border"
            style={i === 0
              ? 'background: var(--accent); color: #071209; border-color: var(--accent);'
              : 'border-color: rgba(0,212,154,0.25); color: rgba(200,230,215,0.5);'}
          >
            <span class="mr-1">{cat.icon}</span>{cat.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Prompts Grid -->
  <section class="max-w-7xl mx-auto px-6 py-12">
    <div id="prompts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {prompts.map((p, idx) => (
        <div
          class="prompt-card rounded-xl overflow-hidden border transition-all duration-400 cursor-pointer group"
          data-category={p.category}
          data-title={p.title.toLowerCase()}
          data-idx={idx}
          style="background: #0a1f12; border-color: rgba(0,212,154,0.2);"
          onclick={`togglePrompt(${idx})`}
        >
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={p.img}
              alt={p.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          </div>

          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] tracking-[0.2em] uppercase px-2 py-1 rounded-full border" style="color: var(--accent); border-color: rgba(0,212,154,0.25);">
                {categoryNames[p.category] || p.category}
              </span>
              {p.author && (
                <span class="text-[10px] tracking-wider" style="color: rgba(200,230,215,0.5);">
                  {p.author}
                </span>
              )}
            </div>

            <h3 class="text-lg font-light tracking-wide mb-2" style="color: var(--text-primary); font-family: 'Cormorant Garamond', serif;">
              {p.title}
            </h3>

            <div class="prompt-preview text-xs p-3 rounded-lg mb-4 overflow-hidden" style="background: rgba(0,0,0,0.3); color: rgba(200,230,215,0.5);">
              <p class="line-clamp-3">{p.prompt}</p>
            </div>

            <div class="flex items-center justify-between pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
              <button
                onclick={`event.stopPropagation(); copyPrompt(${idx})`}
                data-prompt={p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-3 py-1.5 rounded-full border transition-all duration-300"
                style="border-color: rgba(0,212,154,0.25); color: var(--accent);"
              >
                <span>📋</span> 复制
              </button>
              <span class="text-xs" style="color: rgba(200,230,215,0.5);">点击展开 ↓</span>
            </div>
          </div>

          <div class="prompt-full hidden px-5 pb-5">
            <div class="text-xs p-4 rounded-lg overflow-auto max-h-[300px]" style="background: rgba(0,0,0,0.4); color: var(--text-primary);">
              <pre class="whitespace-pre-wrap text-xs leading-relaxed">{p.prompt}</pre>
            </div>
            <div class="flex items-center justify-between mt-4 pt-3 border-t" style="border-color: rgba(0,212,154,0.2);">
              <button
                onclick={`event.stopPropagation(); copyPrompt(${idx})`}
                data-prompt={p.prompt.replace(/`/g, '\\`').replace(/\$/g, '\\$')}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
                style="background: var(--accent); color: #071209;"
              >
                <span>✓</span> 复制完整提示词
              </button>
              <button onclick={`event.stopPropagation(); togglePrompt(${idx})`} class="text-xs px-3 py-1.5 rounded-full border" style="border-color: rgba(0,212,154,0.25); color: rgba(200,230,215,0.5);">
                收起
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-2xl mb-2" style="color: var(--gold-text); font-family: 'Cormorant Garamond', serif;">暂无匹配</p>
      <p class="text-sm" style="color: rgba(200,230,215,0.5);">尝试其他关键词或分类</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t py-10 px-6" style="border-color: rgba(0,212,154,0.2);">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-xs tracking-widest uppercase mb-4" style="color: var(--gold-text);">Rubin Roven Prompts</p>
      <p style="color: rgba(200,230,215,0.5);">
        基于 GPT Image 2 · 仅供学习参考
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prompt-card:hover {
    border-color: var(--accent) !important;
    box-shadow: 0 0 30px rgba(0,212,154,0.15);
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #071209; }
  ::-webkit-scrollbar-thumb { background: rgba(0,212,154,0.25); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
</style>

<script define:vars={{ prompts }}>
{
  const tabs = document.querySelectorAll('#category-tabs button');
  const cards = document.querySelectorAll('.prompt-card');
  const searchInput = document.getElementById('search-input');
  const emptyState = document.getElementById('empty-state');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.category;

      tabs.forEach(t => {
        t.style.background = 'transparent';
        t.style.color = 'rgba(200,230,215,0.5)';
        t.style.borderColor = 'rgba(0,212,154,0.25)';
      });
      tab.style.background = 'var(--accent)';
      tab.style.color = '#071209';
      tab.style.borderColor = 'var(--accent)';

      cards.forEach(card => {
        if (cat === 'all' || card.dataset.category === cat) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });

      checkEmpty();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();

    cards.forEach(card => {
      const title = card.dataset.title || '';
      if (title.includes(q) || q === '') {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });

    checkEmpty();
  });

  function checkEmpty() {
    const visible = [...cards].filter(c => c.style.display !== 'none');
    emptyState?.classList.toggle('hidden', visible.length > 0);
  }

  window.togglePrompt = function(idx) {
    const card = document.querySelector(`[data-idx="${idx}"]`);
    if (!card) return;
    const preview = card.querySelector('.prompt-preview');
    const full = card.querySelector('.prompt-full');
    const toggleBtn = card.querySelector('.flex.items-center.justify-between.pt-3 button:last-child');

    if (full?.classList.contains('hidden')) {
      full.classList.remove('hidden');
      preview?.classList.add('hidden');
      if (toggleBtn) toggleBtn.textContent = '收起';
    } else {
      full?.classList.add('hidden');
      preview?.classList.remove('hidden');
      if (toggleBtn) toggleBtn.textContent = '点击展开 ↓';
    }
  };

  window.copyPrompt = function(idx) {
    const card = document.querySelector(`[data-idx="${idx}"]`);
    if (!card) return;
    const btn = event.target.closest('button');
    if (!btn) return;
    const promptData = btn.dataset.prompt;
    navigator.clipboard.writeText(promptData).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = '<span>✓</span> 已复制';
      setTimeout(() => {
        btn.innerHTML = original;
      }, 1500);
    });
  };
}
</script>