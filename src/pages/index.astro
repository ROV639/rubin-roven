---
import BaseLayout from '../layouts/BaseLayout.astro';

const gallery = [
  { id: '01', title: '黎明', category: '自然', thumb: 'https://picsum.photos/seed/dawn/400/500', url: '#' },
  { id: '02', title: '暮色', category: '城市', thumb: 'https://picsum.photos/seed/dusk/400/400', url: '#' },
  { id: '03', title: '静谧', category: '建筑', thumb: 'https://picsum.photos/seed/quiet/400/600', url: '#' },
  { id: '04', title: '流动', category: '抽象', thumb: 'https://picsum.photos/seed/flow/400/400', url: '#' },
  { id: '05', title: '光影', category: '人像', thumb: 'https://picsum.photos/seed/light/400/500', url: '#' },
  { id: '06', title: '夜色', category: '城市', thumb: 'https://picsum.photos/seed/night/400/400', url: '#' },
];

const categories = ['全部', '自然', '城市', '建筑', '抽象', '人像'];
---

<BaseLayout title="Gallery — Rubin Roven">
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-block text-xs tracking-[0.3em] uppercase px-4 py-1.5 rounded-full border border-[var(--accent-border)] accent-text mb-10" style="background: rgba(0,212,154,0.08);">
        Collection
      </div>

      <!-- Main titles - same size, same font -->
      <h1 class="text-6xl md:text-8xl font-light tracking-[0.12em] leading-none mb-2 text-[var(--gold-text)] hero-title" style="font-family: 'Cormorant Garamond', serif;">
        RUBIN
      </h1>
      <h2 class="text-6xl md:text-8xl font-light tracking-[0.12em] leading-none mb-10 text-[var(--gold-text)] hero-title" style="font-family: 'Cormorant Garamond', serif;">
        ROVEN
      </h2>

      <!-- Subtitle -->
      <p class="text-lg font-light leading-loose max-w-lg mx-auto mb-14" style="color: var(--text-dim);">
        记录所见，探索所知。<br />
        让每一次定格，都成为时间的标本。
      </p>

      <!-- Decorative divider -->
      <div class="flex items-center justify-center gap-3 mb-14">
        <span class="w-1 h-1 rounded-full bg-[var(--accent)] opacity-30"></span>
        <span class="w-1 h-1 rounded-full bg-[var(--accent)] opacity-50"></span>
        <span class="w-1 h-1 rounded-full bg-[var(--accent)] opacity-80"></span>
      </div>

      <!-- CTA Button -->
      <div class="flex items-center justify-center gap-5">
        <a href="#gallery" class="group inline-flex items-center gap-3 px-8 py-3 rounded-md border border-[var(--accent-border)] text-[var(--gold-text)] text-sm tracking-[0.2em] uppercase hover:bg-[var(--accent)] hover:text-[var(--bg-deep)] transition-all duration-500" style="background: rgba(0,212,154,0.05);">
          <span>开始探索</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="max-w-7xl mx-auto px-6 py-24">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-px bg-[var(--accent)]"></span>
          <span class="accent-text text-xs tracking-[0.3em] uppercase">Gallery</span>
        </div>
        <h2 class="text-4xl font-light tracking-tight text-[var(--gold-text)]" style="font-family: 'Cormorant Garamond', serif;">精选作品</h2>
      </div>

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2">
        {categories.map((cat, i) => (
          <button
            data-category={cat === '全部' ? 'all' : cat}
            class={`px-5 py-2 text-xs tracking-[0.15em] uppercase border rounded-md transition-all duration-400 ${
              i === 0
                ? 'bg-[var(--accent)] text-[var(--bg-deep)] border-[var(--accent)]'
                : 'border-[var(--accent-border)] text-[var(--gold-text)]/60 hover:border-[var(--accent)] hover:text-[var(--gold-text)]'
            }`}
            style="font-family: 'Cormorant Garamond', serif;"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-6" id="gallery-grid">
      {gallery.map((img, i) => (
        <a
          href={img.url}
          class={`group block relative overflow-hidden cursor-pointer card ${
            i % 3 === 1 ? 'md:mt-10' : ''
          } ${i % 3 === 2 ? 'md:mt-5' : ''}`}
          data-category={img.category}
          style={`animation: fadeInUp 0.7s ease-out ${i * 0.12}s both;`}
        >
          <div class="aspect-[4/5] w-full overflow-hidden">
            <img
              src={img.thumb}
              alt={img.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <!-- Overlay -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-6" style="background: linear-gradient(to top, rgba(7,18,9,0.9) 0%, rgba(7,18,9,0.4) 50%, transparent 100%);">
            <span class="accent-text text-[10px] tracking-[0.3em] uppercase mb-1 opacity-80">{img.category}</span>
            <h3 class="text-[var(--text-primary)] text-xl font-light tracking-wide">{img.title}</h3>
          </div>

          <!-- Corner accent -->
          <div class="absolute top-4 left-4 w-6 h-6 border-l border-t border-[var(--accent)]/0 group-hover:border-[var(--accent)]/50 transition-all duration-500"></div>
          <div class="absolute bottom-4 right-4 w-6 h-6 border-r border-b border-[var(--accent)]/0 group-hover:border-[var(--accent)]/50 transition-all duration-500"></div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-32">
      <p class="dim-text text-lg font-light tracking-wide mb-2">暂无匹配内容</p>
      <p class="text-[var(--accent)]/30 text-sm">更多内容持续上传中</p>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hero title hover - normal state is gold, hover makes it white */
  .hero-title {
    color: var(--gold-text);
    transition: color 0.4s ease, transform 0.4s ease;
    display: inline-block;
    cursor: default;
  }
  .hero-title:hover {
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  /* Button hover effects */
  button[data-category] {
    transition: all 0.4s ease;
  }
  button[data-category]:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 212, 154, 0.15);
  }

  /* CTA button hover */
  a[href="#gallery"]:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 212, 154, 0.25);
  }
  a[href="#gallery"]:hover svg {
    animation: bounceDown 0.6s ease infinite;
  }
  @keyframes bounceDown {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }
</style>

<script>
  const buttons = document.querySelectorAll('button[data-category]');
  const items = document.querySelectorAll('#gallery-grid a');
  const emptyState = document.getElementById('empty-state');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');

      buttons.forEach(b => {
        b.classList.remove('bg-[var(--accent)]', 'text-[var(--bg-deep)]', 'border-[var(--accent)]');
        b.classList.add('border-[var(--accent-border)]', 'dim-text');
      });
      btn.classList.add('bg-[var(--accent)]', 'text-[var(--bg-deep)]', 'border-[var(--accent)]');
      btn.classList.remove('border-[var(--accent-border)]', 'dim-text');

      let visible = 0;
      items.forEach(item => {
        const itemCat = item.getAttribute('data-category');
        if (cat === 'all' || itemCat === cat) {
          item.style.display = 'block';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visible > 0);
      }
    });
  });
</script>