---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Rubin Roven">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <!-- Header -->
    <div class="text-center mb-20">
      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="w-12 h-px bg-[var(--gold-warm)] opacity-40"></span>
        <span class="text-[var(--gold-warm)] text-xs tracking-[0.4em] uppercase">About</span>
        <span class="w-12 h-px bg-[var(--gold-warm)] opacity-40"></span>
      </div>
      <h1 class="text-5xl md:text-6xl font-light tracking-[0.08em] text-[var(--green-deep)] mb-4">Rubin Roven</h1>
      <p class="text-[var(--green-moss)]/70 font-light tracking-widest text-sm italic">关于这个项目</p>
    </div>

    <!-- Decorative divider -->
    <div class="flex items-center justify-center gap-3 mb-20">
      <span class="w-24 h-px bg-[var(--gold-warm)] opacity-30"></span>
      <span class="w-2 h-2 rounded-full border border-[var(--gold-warm)] opacity-50"></span>
      <span class="w-24 h-px bg-[var(--gold-warm)] opacity-30"></span>
    </div>

    <!-- Content -->
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: Story -->
      <div class="space-y-10">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--gold-warm)]"></span>
            <h3 class="text-lg font-light tracking-[0.1em] text-[var(--green-deep)] uppercase">我们的故事</h3>
          </div>
          <p class="text-[var(--green-moss)]/80 leading-loose font-light text-sm pl-4 border-l border-[var(--gold-light)]/30">
            Rubin Roven 是一个素材存档项目，致力于收集和整理视觉创作中的灵感和片段。我们相信，每一张图片都是时间的切片，每一个构图都是情感的凝结。
          </p>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--gold-warm)]"></span>
            <h3 class="text-lg font-light tracking-[0.1em] text-[var(--green-deep)] uppercase">创作理念</h3>
          </div>
          <p class="text-[var(--green-moss)]/80 leading-loose font-light text-sm pl-4 border-l border-[var(--gold-light)]/30">
            在碎片化的信息时代，我们更注重沉淀与积累。每一件作品，都经过精心筛选；每一个分类，都经过反复推敲，让素材回归素材，让创作回归创作。
          </p>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--gold-warm)]"></span>
            <h3 class="text-lg font-light tracking-[0.1em] text-[var(--green-deep)] uppercase">未来规划</h3>
          </div>
          <p class="text-[var(--green-moss)]/80 leading-loose font-light text-sm pl-4 border-l border-[var(--gold-light)]/30">
            这是一个持续生长的项目。随着素材库的丰富，我们将逐步开放投稿功能，邀请更多创作者加入，共同构建这个开放的视觉存档。
          </p>
        </div>
      </div>

      <!-- Right: Stats -->
      <div class="space-y-6">
        <!-- Stats cards -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { num: '∞', label: '持续更新', color: 'text-[var(--green-deep)]' },
            { num: '精选', label: '品质优先', color: 'text-[var(--gold-warm)]' },
            { num: '开放', label: '共建共享', color: 'text-[var(--green-forest)]' },
            { num: '免费', label: '无门槛', color: 'text-[var(--leather)]' },
          ].map(stat => (
            <div class="p-6 bg-[var(--cream-dark)] border border-[var(--gold-light)]/30 text-center">
              <p class={`text-2xl font-light mb-1 ${stat.color}`}>{stat.num}</p>
              <p class="text-[var(--green-moss)]/60 text-[10px] tracking-[0.2em] uppercase">{stat.label}</p>
            </div>
          ))}
        </div>

        <!-- Contact card -->
        <div class="p-6 bg-[var(--cream-dark)] border border-[var(--gold-light)]/30">
          <h4 class="text-[var(--green-deep)] text-sm font-light tracking-[0.15em] uppercase mb-5">联系方式</h4>
          <div class="space-y-3">
            {[
              '素材投稿，合作邀请',
              '持续关注更新',
              '更多内容开放中',
            ].map((item, i) => (
              <div class="flex items-center gap-3 text-sm text-[var(--green-moss)]/70 font-light">
                <span class="w-1 h-1 rounded-full bg-[var(--gold-warm)] opacity-60"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Tech stack -->
        <div class="p-6 bg-[var(--cream-dark)] border border-[var(--gold-light)]/30">
          <h4 class="text-[var(--green-deep)] text-sm font-light tracking-[0.15em] uppercase mb-5">技术栈</h4>
          <div class="flex flex-wrap gap-2">
            {['Astro 5', 'Tailwind CSS', 'Cloudflare Pages', 'GitHub'].map(tech => (
              <span class="px-3 py-1 bg-[var(--cream)] border border-[var(--gold-light)]/40 text-[var(--green-moss)]/80 text-xs tracking-wider">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Back link -->
    <div class="text-center mt-20">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="w-8 h-px bg-[var(--gold-light)] opacity-30"></span>
      </div>
      <a href="/" class="inline-flex items-center gap-2 text-[var(--green-moss)]/60 hover:text-[var(--green-deep)] transition-colors duration-300 text-sm tracking-wider group">
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
        </svg>
        返回 Gallery
      </a>
    </div>
  </section>
</BaseLayout>